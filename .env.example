# Required — your API key from the mikr.us panel (https://mikr.us/panel)
MIKRUS_API_KEY=your_api_key_here

# Required — your server identifier (e.g. your_srv)
MIKRUS_SERVER_NAME=your_server_name_here

# Optional — custom API endpoint (default: https://api.mikr.us)
# MIKRUS_API_URL=https://api.mikr.us
