# =============================================================================
# Configuration modes
# =============================================================================
# Use either single-server mode (Option A) OR multi-server JSON (Option B/C).
# Do NOT mix both — multi-server takes precedence.
#
# Variable aliases (MCP_* and MIKRUS_* are interchangeable):
#   MCP_SERVERS        ←→ MIKRUS_SERVERS
#   MCP_DEFAULT_SERVER ←→ MIKRUS_DEFAULT_SERVER
# =============================================================================

# -----------------------------------------------------------------------------
# Option A — Single mikrus server (API mode)
# -----------------------------------------------------------------------------
MIKRUS_API_KEY=your_api_key_here
MIKRUS_SERVER_NAME=your_server_name_here
# MIKRUS_API_URL=https://api.mikr.us   # optional

# -----------------------------------------------------------------------------
# Option B — Multi-server JSON (mikrus + SSH)
# -----------------------------------------------------------------------------
# MCP_SERVERS={
#   "your_srv": {"type": "mikrus", "key": "xxx", "srv": "your_srv"},
#   "myssh":   {"type": "ssh", "host": "192.168.1.10", "port": 22, "user": "root", "password": "secret", "sudo_password": "secret"},
#   "certssh": {"type": "ssh", "host": "10.0.0.5", "port": 22, "user": "admin", "ssh_key": "/home/user/.ssh/id_ed25519", "ssh_cert": "/home/user/.ssh/id_ed25519-cert.pub"}
# }
# MCP_DEFAULT_SERVER=your_srv   # optional — auto-picks first server if omitted
#
# The MIKRUS_SERVERS name also works as an alias:
# MIKRUS_SERVERS={"myssh": {"type": "ssh", "host": "10.0.0.5", ...}}

# -----------------------------------------------------------------------------
# Option C — SSH-only (no mikr.us account needed)
# -----------------------------------------------------------------------------
# MCP_SERVERS={
#   "prod": {"type": "ssh", "host": "prod.example.com", "user": "admin", "ssh_key": "/home/user/.ssh/id_ed25519"}
# }
# MCP_DEFAULT_SERVER=prod
#
# Optional SSH fields:
#   ssh_key       — Path to SSH private key file (permissions should be 600)
#   ssh_cert      — Path to SSH certificate file (signed by CA, optional)
#   password      — SSH password (optional, only if key auth is not used)
#   sudo_password — Required for journalctl tools if the user is not in the
#                   'systemd-journal' or 'adm' group. If omitted, journal tools
#                   will still work but may return a hint asking the user to
#                   configure it when privileges are insufficient.
#   verify_host_key — Verify SSH host key (default: false)
#   known_hosts_file — Path to known_hosts file (used when verify_host_key=true)
#   timeout       — SSH connection timeout in seconds (default: 30)

# -----------------------------------------------------------------------------
# Optional MCP transport
# -----------------------------------------------------------------------------
# Leave empty for stdio (default). Set a port to enable SSE transport.
# MCP_PORT=8300
# MCP_HOST=127.0.0.1
# To bind to 0.0.0.0, also set MCP_UNSAFE_PUBLIC_ACCESS_CONFIRMED=1

# -----------------------------------------------------------------------------
# Optional logging
# -----------------------------------------------------------------------------
# LOG_LEVEL=INFO   # DEBUG, INFO, WARNING, ERROR
